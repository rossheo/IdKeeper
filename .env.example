# docker-compose.yaml이 참조하는 환경변수 예시. 이 파일을 .env로 복사한 뒤 값을 채운다.
# .env는 .gitignore에 의해 저장소에 커밋되지 않는다.

# GHCR에 올라간 이미지 태그. 로컬에서 직접 빌드한 이미지를 쓰려면
# `dotnet publish <csproj> -c Release --os linux --arch x64 -t:PublishContainer
#  -p:ContainerRepository=idkeeper-apiservice -p:ContainerImageTag=local` 처럼 만든 뒤
# 아래 값을 그 태그(예: idkeeper-apiservice:local)로 바꾼다.
APISERVICE_IMAGE=ghcr.io/rossheo/idkeeper-apiservice:latest
APISERVICE_PORT=8080

SNOWFLAKEAPISERVICE_IMAGE=ghcr.io/rossheo/idkeeper-snowflakeapiservice:latest
SNOWFLAKEAPISERVICE_PORT=8080
# ApiService(Web 관리자 페이지의 X-API 관리)에 등록한 X-API 키. 반드시 "idkeeper-"로
# 시작해야 한다.
SNOWFLAKEAPISERVICE_XAPIKEY=idkeeper-<여기에-발급받은-키>

WEB_IMAGE=ghcr.io/rossheo/idkeeper-web:latest
WEB_PORT=8081

# Redis 컨테이너 비밀번호. 임의의 강력한 값으로 채운다.
REDIS_PASSWORD=<강력한-비밀번호>
