@page "/"
@rendermode InteractiveServer

@inject AllocatedIdRepository AllocatedIdRepository

<PageTitle>Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Style="padding-top:1rem; padding-bottom:1rem;">
	<div class="mb-4">
		<MudText Typo="Typo.h4">Dashboard</MudText>
		<MudText Typo="Typo.body2" Class="mud-text-secondary">
			SnowflakeId의 NodeId 할당/잔여 현황을 한눈에 확인합니다.
		</MudText>
	</div>

	<MudCard Class="mb-4" Elevation="1">
		<MudCardContent>
			<MudText Typo="Typo.h6" Class="mb-3">Id 비트 구성 요약 (64-bit)</MudText>

			<MudStack Row="true" Wrap="Wrap.NoWrap" Spacing="0"
					  Style="height:40px; width:100%; overflow:hidden; border-radius:6px;">
				<MudTooltip Text="부호 비트 · 1비트 (항상 0)">
					<MudPaper Style="@SignBitStyle">부호</MudPaper>
				</MudTooltip>
				<MudTooltip Text="@TimeStampTooltip">
					<MudPaper Style="@TimestampStyle">타임스탬프</MudPaper>
				</MudTooltip>
				<MudTooltip Text="@NodeIdTooltip">
					<MudPaper Style="@NodeIdStyle">노드</MudPaper>
				</MudTooltip>
				<MudTooltip Text="@SequenceTooltip">
					<MudPaper Style="@SequenceStyle">시퀀스</MudPaper>
				</MudTooltip>
			</MudStack>
		</MudCardContent>
	</MudCard>

	<MudCard Class="mb-4" Elevation="1">
		<MudCardHeader>
			<CardHeaderContent>
				<MudText Typo="Typo.h6">Node ID 할당/잔여 현황</MudText>
			</CardHeaderContent>
			<CardHeaderActions>
				<MudIconButton Icon="@Icons.Material.Filled.Refresh"
							   OnClick="@RefreshAsync"
							   Disabled="@(_idStats is null)" />
			</CardHeaderActions>
		</MudCardHeader>
		<MudCardContent>
			@if (_idStats is null)
			{
				<MudProgressLinear Indeterminate="true" Color="Color.Primary" />
			}
			else
			{
				<div class="stat-row">
					<div class="stat-item">
						<MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" />
						<div>
							<MudText Typo="Typo.caption" Class="mud-text-secondary">전체 Node ID</MudText>
							<MudText Typo="Typo.h5">@_idStats.Total.ToString("N0")</MudText>
						</div>
					</div>
					<div class="stat-item">
						<MudIcon Icon="@Icons.Material.Filled.Bolt" Color="@_idStats.UsedColor" />
						<div>
							<MudText Typo="Typo.caption" Class="mud-text-secondary">사용 중</MudText>
							<MudText Typo="Typo.h5">@_idStats.Used.ToString("N0")</MudText>
						</div>
					</div>
					<div class="stat-item">
						<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
						<div>
							<MudText Typo="Typo.caption" Class="mud-text-secondary">잔여</MudText>
							<MudText Typo="Typo.h5">@_idStats.Remaining.ToString("N0")</MudText>
						</div>
					</div>
				</div>

				<MudStack Spacing="1" Class="mt-4">
					<MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
						<MudText Typo="Typo.body2">사용률 <b>@(_idStats.UsedPercent.ToString("F2"))%</b></MudText>
						<MudText Typo="Typo.body2" Class="mud-text-secondary">
							잔여 @(_idStats.RemainingPercent.ToString("F2"))%
						</MudText>
					</MudStack>
					<MudProgressLinear Value="@_idStats.UsedPercent"
									   Max="100"
									   Color="@_idStats.UsedColor"
									   Rounded="true"
									   Size="Size.Large"
									   Class="usage-meter" />
				</MudStack>
			}
		</MudCardContent>
	</MudCard>

	<MudCard Elevation="1">
		<MudCardHeader>
			<CardHeaderContent>
				<MudText Typo="Typo.h6">Process별 Id 할당/소비 전략</MudText>
			</CardHeaderContent>
		</MudCardHeader>
		<MudCardContent Class="pt-0">
			<MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4" Dense="true">
				Process마다 1~N개의 Id를 요청할 수 있습니다. 초당 소모량이
				@($"{(1 << SnowflakeConstant.BitCountOfSequenceId) * 1000:#,0}")개를 넘는 경우
				Id를 N개 할당해 애플리케이션 특성에 맞춰 분산 사용합니다.
			</MudAlert>

			<MudText Typo="Typo.subtitle2" Class="mb-1">Id 생성기 N개 사용 패턴</MudText>
			<div class="pattern-list">
				<div class="pattern-row">
					<MudIcon Icon="@Icons.Material.Filled.Repeat" Color="Color.Primary" />
					<MudText Typo="Typo.body2">RoundRobin 방식으로 순차 할당</MudText>
				</div>
				<div class="pattern-row">
					<MudIcon Icon="@Icons.Material.Filled.CallSplit" Color="Color.Primary" />
					<MudText Typo="Typo.body2">ThreadId % N 으로 분배</MudText>
				</div>
				<div class="pattern-row">
					<MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" />
					<MudText Typo="Typo.body2">WorkerThread 수만큼 1:1 고정 매칭</MudText>
				</div>
				<div class="pattern-row">
					<MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" />
					<div>
						<MudText Typo="Typo.body2">요청 크기 기반 동적 분산</MudText>
						<MudText Typo="Typo.caption" Class="mud-text-secondary">
							RoundRobin 시작, ⌈count / maxSeqPerMs⌉개 제너레이터에 청크 병렬 할당
							(SnowflakeHostedService: 단일 요청도 초과 시 복수 제너레이터로 자동 확장)
						</MudText>
					</div>
				</div>
			</div>
		</MudCardContent>
	</MudCard>
</MudContainer>

@code {
	private string _baseDateTime =>
		SnowflakeConstant.BaseDateTime.ToString("yyyy-MM-ddTHH:mm:ssZ");

	private IdStats? _idStats;

	private record IdStats(Int32 Total, Int32 Used)
	{
		public Int32 Remaining => Total - Used;
		public double UsedPercent => Total == 0 ? 0 : (double)Used / Total * 100.0;
		public double RemainingPercent => 100.0 - UsedPercent;
		public Color UsedColor => UsedPercent switch
		{
			>= 90 => Color.Error,
			>= 70 => Color.Warning,
			_ => Color.Success,
		};
	}

	private const string _cellBase =
		"display:flex; align-items:center; justify-content:center;" +
		" font-size:.90rem;";

	private string SignBitStyle =>
		"width:40px; background:var(--mud-palette-secondary); color:var(--mud-palette-secondary-text); " +
		_cellBase + " border-radius:6px 0 0 6px;";

	private string TimestampStyle =>
		$"width:{SnowflakeConstant.BitCountOfTimestamp * 10}px; background:var(--mud-palette-primary); " +
		"color:var(--mud-palette-primary-text); " + _cellBase;

	private string NodeIdStyle =>
		$"width:{SnowflakeConstant.BitCountOfNodeId * 10}px; background:var(--mud-palette-success); " +
		"color:var(--mud-palette-success-text); " + _cellBase;

	private string SequenceStyle =>
		$"width:{SnowflakeConstant.BitCountOfSequenceId * 10}px; background:var(--mud-palette-info); " +
		"color:var(--mud-palette-info-text); " + _cellBase + " border-radius:0 6px 6px 0;";

	public string TimeStampTooltip =>
		$"타임스탬프 · {SnowflakeConstant.BitCountOfTimestamp}비트 (기준 시점 {_baseDateTime}부터의 밀리초)";

	public string NodeIdTooltip =>
		$"노드 Id · {SnowflakeConstant.BitCountOfNodeId}비트 (DataCenterId + WorkerId) {1 << SnowflakeConstant.BitCountOfNodeId:#,0}개";

	public string SequenceTooltip =>
		$"시퀀스 · {SnowflakeConstant.BitCountOfSequenceId}비트 (같은 ms 내에서 순차적 할당, 초당 최대 {1 << SnowflakeConstant.BitCountOfSequenceId:#,0}×1,000개)";

	protected override async Task OnInitializedAsync()
	{
		await LoadStatsAsync();
	}

	private async Task RefreshAsync()
	{
		await LoadStatsAsync();
	}

	private async Task LoadStatsAsync()
	{
		Int32 total = 1 << SnowflakeConstant.BitCountOfNodeId;
		Int64 used = await AllocatedIdRepository.CountOfAllocatedAsync();
		_idStats = new(total, (Int32)Math.Min(used, total));
	}
}
