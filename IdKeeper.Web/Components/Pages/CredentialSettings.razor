@page "/credential-settings"
@rendermode InteractiveServer
@attribute [Authorize(Roles = $"{Role.Administrator},{Role.Maintainer}")]
@using CredentialSettingsModel = IdKeeper.Database.Redis.Models.CredentialSettings

@inject CredentialSettingsRepository CredentialSettingsRepository
@inject AuditLogRepository AuditLogRepository
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<IdentityUser> UserManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Credential 설정</PageTitle>
<MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
	<MudItem>
		<MudText Typo="Typo.h4" Class="mb-2">Credential 설정</MudText>
		<MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
			외부 서비스 Credential을 <b>암호화</b>해 저장합니다(유저별). 시크릿은 다시 표시되지 않으며,
			빈칸으로 저장하면 기존 값이 유지됩니다.
		</MudText>
	</MudItem>

	<MudPaper Elevation="2" Class="pa-4">
		<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
			<MudText Typo="Typo.h6">Discord 알림 웹훅</MudText>
			@if (_settings.DiscordWebhookConfigured)
			{
				<MudChip T="string" Color="Color.Success" Size="Size.Small">설정됨</MudChip>
			}
		</MudStack>

		<MudTextField T="string" @bind-Value="_discordWebhookUrl" Label="Webhook URL"
					   Placeholder="변경하려면 입력 (빈칸 = 기존 값 유지)" />

		<MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4" Spacing="4">
			<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">
				저장
			</MudButton>
			<MudButton Variant="Variant.Outlined" Color="Color.Error"
					   Disabled="@(!_settings.DiscordWebhookConfigured)"
					   OnClick="RemoveAsync">
				제거
			</MudButton>
			@if (_settings.LastSavedAtUtc is not null)
			{
				<MudText Typo="Typo.body2" Color="Color.Secondary">
					마지막 저장: @_settings.LastSavedAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
				</MudText>
			}
		</MudStack>
	</MudPaper>
</MudContainer>

@code {
	private CredentialSettingsModel _settings = new();
	private string? _discordWebhookUrl;
	private string _actor = string.Empty;
	private string _userId = string.Empty;

	protected override async Task OnInitializedAsync()
	{
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		_actor = authState.User.Identity?.Name ?? "unknown";

		IdentityUser? user = await UserManager.GetUserAsync(authState.User);
		if (user is null)
		{
			return;
		}
		_userId = user.Id;

		_settings = await CredentialSettingsRepository.GetAsync(_userId);
	}

	private async Task SaveAsync()
	{
		try
		{
			bool updated = await CredentialSettingsRepository.SetDiscordWebhookAsync(_userId, _discordWebhookUrl);
			_discordWebhookUrl = null;

			if (!updated)
			{
				Snackbar.Add("변경된 값이 없어 기존 설정을 유지합니다.", Severity.Info);
				return;
			}

			await AuditLogRepository.AppendAsync(
				AuditLogAction.CredentialSettingsUpdated, _actor, detail: $"userId={_userId}, DiscordWebhook");
			_settings = await CredentialSettingsRepository.GetAsync(_userId);

			Snackbar.Add("Credential 설정을 저장했습니다.", Severity.Success);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"저장 실패: {ex.Message}", Severity.Error);
		}
	}

	private async Task RemoveAsync()
	{
		bool? confirmed = await DialogService.ShowMessageBoxAsync(
			"Discord 웹훅 제거 확인",
			"저장된 Discord 웹훅 URL을 제거합니다. 제거하면 이 계정으로는 더 이상 Discord 알림이 전송되지 않습니다. 계속할까요?",
			yesText: "제거",
			cancelText: "취소");

		if (confirmed != true)
		{
			return;
		}

		try
		{
			bool removed = await CredentialSettingsRepository.RemoveDiscordWebhookAsync(_userId);
			if (!removed)
			{
				Snackbar.Add("이미 설정된 웹훅이 없습니다.", Severity.Info);
				return;
			}

			await AuditLogRepository.AppendAsync(
				AuditLogAction.CredentialSettingsRemoved, _actor, detail: $"userId={_userId}, DiscordWebhook");
			_settings = await CredentialSettingsRepository.GetAsync(_userId);
			_discordWebhookUrl = null;

			Snackbar.Add("Discord 웹훅 설정을 제거했습니다.", Severity.Success);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"제거 실패: {ex.Message}", Severity.Error);
		}
	}
}
