@page "/userroles"
@rendermode InteractiveServer
@attribute [Authorize(Roles = $"{Role.Administrator}")]

@inject IdentityUserStore UserStore
@inject ISnackbar Snackbar
@inject UserManager<IdentityUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AuditLogRepository AuditLogRepository

<PageTitle>UserRoles</PageTitle>
<MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
	<MudItem>
		<MudText Typo="Typo.h4" Class="mb-2">UserRoles</MudText>
	</MudItem>

	<MudStack Spacing="4">
		<MudPaper Elevation="2"
				  Class="pa-4 mt-4">
			<MudTable T="UserRoleInfo"
					  Items="@_items"
					  Hover="true"
					  Breakpoint="Breakpoint.Sm"
					  Filter="FilterFunc"
					  Class="mudblazor-table-no-border">
				<ToolBarContent>
					<MudTextField @bind-Value="_searchString"
								  Placeholder="UserName/Role 검색"
								  Adornment="Adornment.Start"
								  AdornmentIcon="@Icons.Material.Filled.Search"
								  Immediate="true"
								  Clearable="true" />
				</ToolBarContent>
				<HeaderContent>
					<MudTh>
						<MudTableSortLabel InitialDirection="SortDirection.Ascending"
										   SortBy="new Func<UserRoleInfo, object>(x => x.UserName)">
							UserName
						</MudTableSortLabel>
					</MudTh>
					<MudTh>
						<MudTableSortLabel InitialDirection="SortDirection.Ascending"
										   SortBy="new Func<UserRoleInfo, object>(x => x.Role)">
							Role
						</MudTableSortLabel>
					</MudTh>
				</HeaderContent>
				<RowTemplate>
					<MudTd DataLabel="UserName">@context.UserName</MudTd>
					<MudTd DataLabel="Role">
						@if (_editingRoleUserName == context.UserName)
						{
							<MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
								<MudSelect T="string"
										   @bind-Value="_editingRole"
										   Variant="Variant.Outlined"
										   Label="Role"
										   Dense="true"
										   Class="mr-1">
									@foreach (var role in _roleNames)
									{
										<MudSelectItem T="string" Value="@role">@role</MudSelectItem>
									}
								</MudSelect>
								<MudIconButton Icon="@Icons.Material.Filled.Check"
											   Color="Color.Success"
											   Size="Size.Small"
											   Disabled="@_savingRole"
											   OnClick="@(() => SaveRoleAsync(context.UserName))" />
								<MudIconButton Icon="@Icons.Material.Filled.Close"
											   Color="Color.Default"
											   Size="Size.Small"
											   Disabled="@_savingRole"
											   OnClick="@CancelEditRole" />
							</MudStack>
						}
						else
						{
							<MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
								<MudText Typo="Typo.body2">
									@((string.IsNullOrWhiteSpace(context.Role) ? "-" : context.Role))
								</MudText>
								<MudIconButton Icon="@Icons.Material.Filled.Edit"
											   Color="Color.Primary"
											   Size="Size.Small"
											   Disabled="@(!string.IsNullOrEmpty(_editingRoleUserName))"
											   OnClick="@(() => BeginEditRole(context))" />
							</MudStack>
						}
					</MudTd>
				</RowTemplate>
				<NoRecordsContent>
					<MudText Typo="Typo.h6" Class="d-flex justify-center py-4">
						<MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
						No records found.
					</MudText>
				</NoRecordsContent>
			</MudTable>
		@if (_isLoading)
		{
			<MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
		}
		</MudPaper>
	</MudStack>
</MudContainer>

@code {
	private List<UserRoleInfo> _items = [];
	private bool _isLoading = true;
	private string[] _roleNames = [];
	private string _actor = string.Empty;

	#region Role Edit
	private string? _editingRoleUserName;
	private string? _editingRole;
	private bool _savingRole;
	#endregion

	#region Filter/Sort
	private string _searchString = string.Empty;

	private bool FilterFunc(UserRoleInfo element)
		=> string.IsNullOrWhiteSpace(_searchString)
		   || (element.UserName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
		   || (element.Role?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
	#endregion

	protected override async Task OnInitializedAsync()
	{
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		_actor = authState.User.Identity?.Name ?? "unknown";

		_roleNames = ReflectionConstant.GetPublicStaticStringMemberValues(typeof(Role));

		try
		{
			List<IdentityUser> users = await UserStore.GetAllUsersAsync();

			List<UserRoleInfo> items = [];
			foreach (IdentityUser u in users)
			{
				IList<string> roles = await UserManager.GetRolesAsync(u);
				items.Add(new UserRoleInfo
				{
					UserName = u.UserName!,
					Role = string.Join(",", roles),
				});
			}
			_items = items;
		}
		finally
		{
			_isLoading = false;
		}
	}

	#region Role Edit
	private void BeginEditRole(UserRoleInfo item)
	{
		if (!string.IsNullOrEmpty(_editingRoleUserName)) return;
		_editingRoleUserName = item.UserName;
		_editingRole = item.Role;
	}

	private void CancelEditRole()
	{
		_editingRoleUserName = null;
		_editingRole = null;
		_savingRole = false;
	}

	private async Task SaveRoleAsync(string userName)
	{
		if (_savingRole) return;
		_savingRole = true;

		try
		{
			var user = await UserManager.FindByNameAsync(userName);
			if (user is null)
			{
				Snackbar.Add("대상을 찾을 수 없습니다.", Severity.Error);
				return;
			}

			if (!string.IsNullOrWhiteSpace(_editingRole))
			{
				await UserManager.AssignRoleAsync(user, _editingRole!);
			}

			var item = _items.SingleOrDefault(r => r.UserName == userName);
			if (item is not null)
			{
				item.Role = _editingRole ?? string.Empty;
			}

			await AuditLogRepository.AppendAsync(
				AuditLogAction.UserRoleChanged, _actor, requester: userName, detail: _editingRole);
			Snackbar.Add($"Role 저장 완료. {userName}, {_editingRole}", Severity.Success);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"저장 실패: {ex.Message}", Severity.Error);
		}
		finally
		{
			CancelEditRole();
			StateHasChanged();
		}
	}
	#endregion
}
